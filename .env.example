# Copy this file to .env and fill in real values.
# Do not commit .env.

API_BASE_URL=https://api.yourdomain.com
DEVICE_ID=home_abc123
DEVICE_TOKEN=your_per_device_token

CAMERA_IP=192.168.1.50
CAMERA_USERNAME=admin
CAMERA_PASSWORD=your_camera_password
CAMERA_RTSP_PORT=554
CAMERA_RTSP_PATH_TEMPLATE=/Streaming/Channels/{channel}

# RTSP stability tuning. Increase these if DVR streams drop briefly under load.
RTSP_OPEN_TIMEOUT_MS=5000
RTSP_READ_TIMEOUT_MS=5000
RTSP_READ_FAILURES_BEFORE_RECONNECT=10
RTSP_RECONNECT_DELAY_SECONDS=2
RECORDING_FPS=20
RECORDING_READ_RETRY_SLEEP_SECONDS=0.05
DETECTION_INTERVAL_SECONDS=1.0

# When false, YOLO pauses after a recording starts, then analyzes the saved clip afterward.
# When true, YOLO and scenario detection continue during recording, then post-save YOLO is skipped.
DETECT_DURING_RECORDING=false

# LM Studio / Gemma local analysis.
# GEMMA_API_URL can be the full OpenAI-compatible chat completions endpoint.
GEMMA_API_URL=http://localhost:1234/v1/chat/completions
GEMMA_MODEL=gemma-4
GEMMA_FRAME_COUNT=6
GEMMA_TIMEOUT_SECONDS=180
GEMMA_MAX_TOKENS=1200
